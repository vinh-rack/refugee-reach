# Infrastructure (match docker-compose service names)
DATABASE_URL=postgresql://newsalerts:newsalerts@postgres:5432/news_alerts
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
REDIS_URL=redis://redis:6379/0

# Postgres container settings
POSTGRES_USER=newsalerts
POSTGRES_PASSWORD=newsalerts
POSTGRES_DB=news_alerts

# API keys
OPENAI_API_KEY=sk-your-openai-key
NEWSAPI_KEY=your-newsapi-key

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_VERSION=v23.0

# App
APP_BASE_URL=http://localhost:8000
